# ------------------------------------------------------------
# Agentic Security Platform — environment variable template
# Copy to .env for local development.  NEVER commit .env.
# ------------------------------------------------------------

# --- Neo4j (Security Graph) ---
# In any non-local environment, replace this with a value managed by SOPS or
# a vault. The literal `changeme` is intentionally the default for the local
# Quickstart so the documented CLI commands (--neo4j-password changeme) work
# without further editing.
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
NEO4J_DATABASE=neo4j

# --- API ---
ASP_API_HOST=0.0.0.0
ASP_API_PORT=8000
ASP_API_LOG_LEVEL=INFO
ASP_API_ENVIRONMENT=development   # development | staging | production

# Comma-separated list of CORS origins. In dev, frontend is on :3000.
ASP_API_CORS_ORIGINS=http://localhost:3000

# --- OpenTelemetry ---
OTEL_SERVICE_NAME=asp-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
# Sample rate for dev; use parent-based ratio in prod
OTEL_TRACES_SAMPLER=always_on

# --- LLM providers (LiteLLM gateway) ---
# Leave unset to disable agent runs that need an LLM.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Default model for agents. Any LiteLLM-supported identifier.
ASP_DEFAULT_MODEL=anthropic/claude-sonnet-4-6

# --- OPA ---
OPA_URL=http://opa:8181
OPA_POLICY_BUNDLE_URL=   # OCI URL to pull signed policy bundles; empty = use local

# --- Ontology version loaded at startup ---
ASP_ONTOLOGY_VERSION=v1

# --- Security hardening toggles ---
# Set to 'true' in any non-local environment.
ASP_REQUIRE_TLS=false
ASP_REQUIRE_SIGNED_POLICIES=false
